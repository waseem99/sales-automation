# App
NODE_ENV=development
APP_BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sales_automation

# AI provider keys. Add only the providers you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# Gmail read-only ingestion
# Preferred for recurring runs: OAuth refresh credentials authorized only with
# https://www.googleapis.com/auth/gmail.readonly
INGESTION_EMAIL_ADDRESS=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Gmail OAuth bootstrap. Add the exact redirect URI to the Google OAuth client.
GMAIL_OAUTH_REDIRECT_URI=http://127.0.0.1:53682/oauth/callback
# The authorization command writes secrets here with local-only file permissions.
GMAIL_OAUTH_OUTPUT_FILE=.env.local
GMAIL_OAUTH_TIMEOUT_SECONDS=300
# Optional mailbox hint shown on Google's authorization screen.
GMAIL_OAUTH_LOGIN_HINT=

# Optional temporary alternative. Access tokens expire quickly and should not be committed.
# GMAIL_ACCESS_TOKEN=

# Gmail API user. "me" uses the authorized mailbox.
GMAIL_USER_ID=me

# Native Gmail search syntax. Default targets Upwork job alerts.
GMAIL_QUERY=(from:(upwork.com) OR subject:(Upwork)) (job OR opportunity OR alert)
# Optional Gmail label name, for example: Lead Alerts
GMAIL_LABEL=
GMAIL_NEWER_THAN_DAYS=2
GMAIL_MAX_RESULTS=50

# Persistent lead store used by the current local MVP.
LEAD_STORE_FILE=.data/leads.json

# Approved Codistan portfolio proof JSON. See docs/GMAIL_INGESTION.md.
PORTFOLIO_FILE=
INCLUDE_PRIVATE_PORTFOLIO=false

# Internal BD alerts
# Slack incoming webhook. This notifies Codistan staff only; it never contacts prospects.
SLACK_WEBHOOK_URL=
# Alert newly captured qualified leads as well as urgent/hot leads.
SLACK_ALERT_QUALIFIED=true
SLACK_ALERT_MAX_ATTEMPTS=3
SLACK_ALERT_RETRY_DELAY_MS=1000
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
WHATSAPP_WEBHOOK_URL=

# Gmail worker. `pnpm worker:gmail` defaults to continuous 30-minute execution.
GMAIL_WORKER_MODE=continuous
GMAIL_WORKER_INTERVAL_MINUTES=30
GMAIL_WORKER_MAX_ATTEMPTS=3
GMAIL_WORKER_RETRY_DELAY_MS=5000
GMAIL_WORKER_LOCK_STALE_MINUTES=90
WORKER_RUN_LOG_FILE=.data/gmail-worker-runs.jsonl
WORKER_STATE_FILE=.data/gmail-worker-state.json
WORKER_LOCK_FILE=.data/gmail-worker.lock

# Enrichment providers. Keep disabled until thresholds and cost controls are implemented.
ENRICHMENT_ENABLED=false
ENRICHMENT_MONTHLY_BUDGET_USD=0

# Safety
AUTO_SEND_OUTREACH=false
AUTO_SUBMIT_UPWORK_PROPOSALS=false
