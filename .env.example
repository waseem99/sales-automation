# Codistan Sales Automation
# Variable names only. Store real secret values in Vercel.

DATABASE_URL=
ADMIN_PASSWORD=
SESSION_SECRET=
CRON_SECRET=

WASEEM_DASHBOARD_PASSWORD=
TALHA_DASHBOARD_PASSWORD=
JAWAD_DASHBOARD_PASSWORD=
MOIZ_DASHBOARD_PASSWORD=
SUBAINA_DASHBOARD_PASSWORD=
DANISH_DASHBOARD_PASSWORD=
HIBA_DASHBOARD_PASSWORD=
BILAL_DASHBOARD_PASSWORD=

PORTFOLIO_LIBRARY_URL=

PROSPECT_MAX_CANDIDATES=15
PROSPECT_MAX_SEARCH_QUERIES=12
# Optional comma-separated subset. Leave blank to run all safe default campaign packs.
# ai_rag_automation,custom_software_saas,white_label_agency,cybersecurity_compliance,immersive_3d_ar_vr,digital_marketing_web
PROSPECT_CAMPAIGN_IDS=
PROSPECT_BING_RSS_ENABLED=true
# Job-board collection is disabled by default; employment signals are not direct sales opportunities.
PROSPECT_REMOTEOK_ENABLED=false
# Optional expert override. When populated, these queries replace campaign-generated searches.
PROSPECT_SEARCH_QUERIES=
PROSPECT_GREENHOUSE_BOARDS=
PROSPECT_LEVER_SITES=
PROSPECT_RSS_FEEDS=

TENDER_MAX_CANDIDATES=80
TENDER_PPRA_ENABLED=true
TENDER_CANADABUYS_ENABLED=true
TENDER_UNGM_ENABLED=true
TENDER_PRIVATE_NONPROFIT_ENABLED=true
TENDER_DIGEST_SUBJECT_PREFIX=Codistan Tender and RFP Pipeline

PROSPECT_DIGEST_TO=
PROSPECT_DIGEST_FROM=
PROSPECT_DIGEST_SUBJECT_PREFIX=Codistan Daily Prospects
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=

SALES_MAILBOX_PASSWORD=
SALES_OUTREACH_SIGNATURE=
OUTREACH_SENDER_EMAILS=sales@codistan.org
OUTREACH_ALERT_EMAILS=waseem@codistan.org,sales@codistan.org
ADDITIONAL_LEAD_OWNERS=
OUTREACH_SMTP_HOST=
OUTREACH_SMTP_PORT=465
OUTREACH_IMAP_HOST=
OUTREACH_IMAP_PORT=993
OUTREACH_REPLY_POLLING_ENABLED=false
OUTREACH_SENDING_ENABLED=false
OUTREACH_DNS_READY=false
OUTREACH_DRY_RUN=true
OUTREACH_RAMP_STARTED_AT=

NODE_ENV=development
PORT=3000
LOCAL_LEAD_STORE_PATH=.data/leads.json
PROSPECT_RUN_STORE_PATH=.data/prospect-runs.json
SEED_SAMPLE_DATA=false
PROSPECT_WORKER_ENABLED=false
