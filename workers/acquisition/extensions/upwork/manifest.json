{
  "manifest_version": 3,
  "name": "Codistan Upwork Opportunity Capture V4",
  "version": "1.0.2",
  "description": "Capture visible jobs from Codistan's three approved Upwork saved searches into the local Acquisition V4 runtime.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "https://www.upwork.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Codistan Upwork capture",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.upwork.com/*"],
      "js": ["evidence.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
