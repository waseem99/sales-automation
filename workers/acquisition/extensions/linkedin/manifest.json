{
  "manifest_version": 3,
  "name": "Codistan LinkedIn Opportunity Capture V4",
  "version": "1.0.4",
  "description": "Capture visible direct agency, vendor and delivery-partner requirements from LinkedIn into the local Acquisition V4 runtime.",
  "permissions": ["activeTab", "tabs", "storage"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://127.0.0.1:8775/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Codistan LinkedIn capture",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["signal.js", "dom-adapter.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}