{
  "version": 2,
  "installCommand": "corepack enable && pnpm install --frozen-lockfile=false",
  "buildCommand": "pnpm build",
  "builds": [
    {
      "src": "apps/web/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/web/api/index.ts"
    }
  ],
  "env": {
    "LOCAL_LEAD_STORE_PATH": "/tmp/codistan-lead-desk-preview.json"
  }
}
