{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm build",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    },
    "api/cron/prospect-discovery.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/prospect-discovery",
      "schedule": "0 4 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/api/cron/prospect-discovery",
      "destination": "/api/cron/prospect-discovery"
    },
    {
      "source": "/",
      "destination": "/api/index?__path=/"
    },
    {
      "source": "/:path*",
      "destination": "/api/index?__path=/:path*"
    }
  ]
}
