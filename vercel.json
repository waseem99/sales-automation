{
  "version": 2,
  "installCommand": "echo 'Skipping dependency install for standalone Vercel preview'",
  "buildCommand": "echo 'Building standalone Codistan Lead Desk preview'",
  "outputDirectory": "public",
  "redirects": [
    {
      "source": "/",
      "destination": "/api/preview",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/api/preview"
    }
  ],
  "env": {
    "LOCAL_LEAD_STORE_PATH": "/tmp/codistan-lead-desk-preview.json"
  }
}
