{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm install --global --prefix \"$PWD/.pnpm-cli\" --force @pnpm/exe@9.15.9 && PATH=\"$PWD/.pnpm-cli/bin:$PATH\" pnpm --version && PATH=\"$PWD/.pnpm-cli/bin:$PATH\" pnpm install --no-frozen-lockfile",
  "buildCommand": "PATH=\"$PWD/.pnpm-cli/bin:$PATH\" pnpm build:vercel",
  "functions": {
    "api/index.ts": {
      "maxDuration": 300
    },
    "api/cron/prospect-discovery.ts": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/cron/prospect-discovery",
      "schedule": "0 4 * * *"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/prospects",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/health",
      "destination": "/api/index?__route=/health"
    },
    {
      "source": "/login",
      "destination": "/api/index?__route=/login"
    },
    {
      "source": "/prospects",
      "destination": "/api/index?__route=/prospects"
    },
    {
      "source": "/lead-desk",
      "destination": "/api/index?__route=/lead-desk"
    },
    {
      "source": "/api/login",
      "destination": "/api/index?__route=/api/login"
    },
    {
      "source": "/api/logout",
      "destination": "/api/index?__route=/api/logout"
    },
    {
      "source": "/api/prospects",
      "destination": "/api/index?__route=/api/prospects"
    },
    {
      "source": "/api/prospect-runs",
      "destination": "/api/index?__route=/api/prospect-runs"
    },
    {
      "source": "/api/prospects/:path*",
      "destination": "/api/index?__route=/api/prospects/:path*"
    },
    {
      "source": "/api/session",
      "destination": "/api/index?__route=/api/session"
    },
    {
      "source": "/api/summary",
      "destination": "/api/index?__route=/api/summary"
    },
    {
      "source": "/api/opportunities",
      "destination": "/api/index?__route=/api/opportunities"
    },
    {
      "source": "/api/opportunities/:path*",
      "destination": "/api/index?__route=/api/opportunities/:path*"
    },
    {
      "source": "/api/ingest/:path*",
      "destination": "/api/index?__route=/api/ingest/:path*"
    },
    {
      "source": "/api/dev/:path*",
      "destination": "/api/index?__route=/api/dev/:path*"
    }
  ]
}
