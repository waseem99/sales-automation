{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": null,
  "installCommand": "npm install --global --prefix \"$PWD/.pnpm-cli\" --force @pnpm/exe@9.15.9 && PATH=\"$PWD/.pnpm-cli/bin:$PATH\" pnpm --version && PATH=\"$PWD/.pnpm-cli/bin:$PATH\" pnpm install --no-frozen-lockfile",
  "buildCommand": "PATH=\"$PWD/.pnpm-cli/bin:$PATH\" pnpm build:vercel",
  "functions": {
    "api/dashboard.ts": { "maxDuration": 300 },
    "api/acquisition-ingest.ts": { "maxDuration": 300 },
    "api/tenders.ts": { "maxDuration": 300 },
    "api/tender-discovery.ts": { "maxDuration": 300 },
    "api/prospect-cleanup.ts": { "maxDuration": 300 },
    "api/contact-enrichment.ts": { "maxDuration": 300 },
    "api/linkedin-signals.ts": { "maxDuration": 300 },
    "api/lead-signals.ts": { "maxDuration": 300 },
    "api/re-engagement.ts": { "maxDuration": 300 },
    "api/delivery-health.ts": { "maxDuration": 300 },
    "api/cron/prospect-discovery.ts": { "maxDuration": 300 },
    "api/cron/linkedin-signals.ts": { "maxDuration": 300 },
    "api/cron/outreach.ts": { "maxDuration": 300 }
  },
  "crons": [
    { "path": "/api/tender-discovery", "schedule": "15 */6 * * *" },
    { "path": "/api/cron/prospect-discovery", "schedule": "0 4 * * *" },
    { "path": "/api/cron/linkedin-signals", "schedule": "*/30 * * * *" },
    { "path": "/api/cron/outreach", "schedule": "0 * * * *" }
  ],
  "redirects": [
    { "source": "/", "destination": "/prospects", "permanent": false }
  ],
  "rewrites": [
    { "source": "/health", "destination": "/api/dashboard?__path=/health" },
    { "source": "/login", "destination": "/api/dashboard?__path=/login" },
    { "source": "/prospects", "destination": "/api/dashboard?__path=/prospects" },
    { "source": "/leads/linkedin", "destination": "/api/dashboard?__path=/leads/linkedin" },
    { "source": "/leads/upwork", "destination": "/api/dashboard?__path=/leads/upwork" },
    { "source": "/leads/rfq", "destination": "/api/dashboard?__path=/leads/rfq" },
    { "source": "/leads/rfp", "destination": "/api/dashboard?__path=/leads/rfp" },
    { "source": "/leads/eoi", "destination": "/api/dashboard?__path=/leads/eoi" },
    { "source": "/leads/rfi", "destination": "/api/dashboard?__path=/leads/rfi" },
    { "source": "/leads/tenders", "destination": "/api/dashboard?__path=/leads/tenders" },
    { "source": "/leads/research", "destination": "/api/dashboard?__path=/leads/research" },
    { "source": "/leads/partnerships", "destination": "/api/dashboard?__path=/leads/partnerships" },
    { "source": "/services", "destination": "/api/dashboard?__path=/services" },
    { "source": "/services/ai", "destination": "/api/dashboard?__path=/services/ai" },
    { "source": "/services/software", "destination": "/api/dashboard?__path=/services/software" },
    { "source": "/services/cybersecurity", "destination": "/api/dashboard?__path=/services/cybersecurity" },
    { "source": "/services/immersive", "destination": "/api/dashboard?__path=/services/immersive" },
    { "source": "/services/marketing", "destination": "/api/dashboard?__path=/services/marketing" },
    { "source": "/priorities", "destination": "/api/dashboard?__path=/priorities" },
    { "source": "/portfolio", "destination": "/api/dashboard?__path=/portfolio" },
    { "source": "/operations", "destination": "/api/dashboard?__path=/operations" },
    { "source": "/lead-signals", "destination": "/api/lead-signals" },
    { "source": "/linkedin-signals", "destination": "/api/linkedin-signals" },
    { "source": "/re-engagement", "destination": "/api/re-engagement" },
    { "source": "/delivery-health", "destination": "/api/delivery-health" },
    { "source": "/tenders", "destination": "/api/tenders" },
    { "source": "/api/login", "destination": "/api/dashboard?__path=/api/login" },
    { "source": "/api/logout", "destination": "/api/dashboard?__path=/api/logout" },
    { "source": "/api/session", "destination": "/api/dashboard?__path=/api/session" },
    { "source": "/api/portfolio-catalog", "destination": "/api/dashboard?__path=/api/portfolio-catalog" },
    { "source": "/api/closeability-rescore", "destination": "/api/dashboard?__path=/api/closeability-rescore" },
    { "source": "/api/source-controls", "destination": "/api/dashboard?__path=/api/source-controls" },
    { "source": "/api/prospects", "destination": "/api/dashboard?__path=/api/prospects" },
    { "source": "/api/prospect-runs", "destination": "/api/dashboard?__path=/api/prospect-runs" },
    { "source": "/api/prospects/:path*", "destination": "/api/dashboard?__path=/api/prospects/:path*" }
  ]
}
