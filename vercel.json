{
  "version": 2,
  "installCommand": "npm install --global pnpm@10.14.0 && pnpm install --frozen-lockfile=false --fetch-retries=5",
  "buildCommand": "pnpm build:vercel",
  "rewrites": [
    {
      "source": "/((?!api).*)",
      "destination": "/api"
    }
  ],
  "env": {
    "LOCAL_LEAD_STORE_PATH": "/tmp/codistan-lead-desk-preview.json"
  }
}
