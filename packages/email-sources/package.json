{
  "name": "@sales-automation/email-sources",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/index.test.ts && tsx src/gmail.test.ts && tsx src/run-gmail-worker.test.ts && tsx src/authorize-gmail.test.ts",
    "authorize:gmail": "node dist/cli.js authorize",
    "ingest:gmail": "node dist/cli.js ingest",
    "worker:gmail": "node dist/cli.js worker"
  },
  "dependencies": {
    "@sales-automation/alerts": "workspace:*",
    "@sales-automation/ingestion": "workspace:*",
    "@sales-automation/shared": "workspace:*",
    "@sales-automation/storage": "workspace:*"
  },
  "devDependencies": {
    "@sales-automation/fixtures": "workspace:*",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
