{
  "name": "@sales-automation/outreach-email",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./linkedin-signal-inbox": {
      "types": "./dist/linkedin-signal-inbox.d.ts",
      "default": "./dist/linkedin-signal-inbox.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/index.test.ts && tsx src/linkedin-signal-inbox.test.ts"
  },
  "dependencies": {
    "@sales-automation/engagement-guidance": "workspace:*",
    "@sales-automation/shared": "workspace:*",
    "@sales-automation/storage": "workspace:*",
    "imapflow": "^1.0.0",
    "mailparser": "^3.7.0",
    "nodemailer": "^7.0.0"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.0",
    "@types/nodemailer": "^6.4.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
