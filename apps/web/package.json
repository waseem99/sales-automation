{
  "name": "@sales-automation/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./prospect-handler": {
      "types": "./dist/auto-prospect-handler.d.ts",
      "default": "./dist/auto-prospect-handler.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/dev.ts",
    "start": "node dist/dev.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "tsx src/prospect-server.test.ts && tsx src/dashboard-access.test.ts && tsx src/auto-prospect-handler.test.ts && tsx src/legacy-boundary.test.ts"
  },
  "dependencies": {
    "@sales-automation/engagement-guidance": "workspace:*",
    "@sales-automation/evaluator": "workspace:*",
    "@sales-automation/prospect-discovery": "workspace:*",
    "@sales-automation/shared": "workspace:*",
    "@sales-automation/storage": "workspace:*"
  },
  "devDependencies": {
    "@sales-automation/fixtures": "workspace:*",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
