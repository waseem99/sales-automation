{
  "name": "codistan-sales-automation",
  "version": "0.1.0",
  "private": true,
  "description": "Internal opportunity intelligence platform for Codistan sales prospecting and qualification.",
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "build": "pnpm -r --filter \"@sales-automation/*\" --sort build",
    "build:vercel": "pnpm build",
    "dev": "pnpm --filter @sales-automation/web dev",
    "start:web": "pnpm --filter @sales-automation/web start",
    "deploy:check": "pnpm install --no-frozen-lockfile && pnpm build",
    "evaluate:sample": "pnpm build && pnpm --filter @sales-automation/cli evaluate:sample",
    "evaluate:json": "pnpm build && pnpm --filter @sales-automation/cli evaluate:json",
    "authorize:gmail": "pnpm build && pnpm --filter @sales-automation/email-sources authorize:gmail",
    "ingest:gmail": "pnpm build && pnpm --filter @sales-automation/email-sources ingest:gmail",
    "worker:gmail": "pnpm build && pnpm --filter @sales-automation/email-sources worker:gmail",
    "lint": "pnpm build && pnpm -r --filter \"@sales-automation/*\" --sort lint",
    "test": "pnpm build && pnpm -r --filter \"@sales-automation/*\" --sort test",
    "typecheck": "pnpm build && pnpm -r --filter \"@sales-automation/*\" --sort typecheck"
  },
  "engines": {
    "node": "24.x"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
