{
  "name": "codistan-sales-automation",
  "version": "0.1.0",
  "private": true,
  "description": "Internal opportunity intelligence platform for Codistan sales prospecting and qualification.",
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r --filter \"@sales-automation/*\" --sort build",
    "build:vercel": "pnpm build && pnpm test:vercel-runtime",
    "test:vercel-runtime": "tsx scripts/vercel-runtime-smoke.ts",
    "dev": "pnpm --filter @sales-automation/web dev",
    "start:web": "pnpm --filter @sales-automation/web start",
    "deploy:check": "pnpm install --no-frozen-lockfile && pnpm build && pnpm typecheck:vercel && pnpm test:vercel-runtime",
    "typecheck:vercel": "tsc -p tsconfig.vercel.json --noEmit",
    "evaluate:sample": "pnpm build && pnpm --filter @sales-automation/cli evaluate:sample",
    "evaluate:json": "pnpm build && pnpm --filter @sales-automation/cli evaluate:json",
    "authorize:gmail": "pnpm build && pnpm --filter @sales-automation/email-sources authorize:gmail",
    "ingest:gmail": "pnpm build && pnpm --filter @sales-automation/email-sources ingest:gmail",
    "worker:gmail": "pnpm build && pnpm --filter @sales-automation/email-sources worker:gmail",
    "prospects:run": "pnpm build && pnpm --filter @sales-automation/prospect-discovery run",
    "worker:prospects": "pnpm build && pnpm --filter @sales-automation/prospect-discovery worker",
    "lint": "pnpm build && pnpm -r --filter \"@sales-automation/*\" --sort lint",
    "test": "pnpm build && pnpm -r --filter \"@sales-automation/*\" --sort test && pnpm test:vercel-runtime",
    "typecheck": "pnpm build && pnpm -r --filter \"@sales-automation/*\" --sort typecheck && pnpm typecheck:vercel"
  },
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@sales-automation/evaluator": "workspace:*",
    "@sales-automation/fixtures": "workspace:*",
    "@sales-automation/neon-state": "workspace:*",
    "@sales-automation/prospect-discovery": "workspace:*",
    "@sales-automation/shared": "workspace:*",
    "@sales-automation/web": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
