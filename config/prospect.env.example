# Add these names in Vercel > Project > Settings > Environment Variables.
# Do not commit or share real secret values.

# Neon Postgres. Vercel/Neon normally creates this automatically.
DATABASE_URL=

# Internal dashboard access
ADMIN_PASSWORD=
SESSION_SECRET=
CRON_SECRET=
DASHBOARD_ACTOR=bd-team@codistan.org

# Lean Vercel discovery limits
PROSPECT_MAX_CANDIDATES=15
PROSPECT_MAX_SEARCH_QUERIES=10
PROSPECT_BING_RSS_ENABLED=true
PROSPECT_REMOTEOK_ENABLED=true
PROSPECT_SEARCH_QUERIES=
PROSPECT_GREENHOUSE_BOARDS=
PROSPECT_LEVER_SITES=
PROSPECT_RSS_FEEDS=

# Daily internal digest. Multiple recipients may be comma-separated.
PROSPECT_DIGEST_TO=
PROSPECT_DIGEST_FROM=
PROSPECT_DIGEST_SUBJECT_PREFIX=Codistan Daily Prospects

# Use the outgoing SMTP settings of an existing mailbox on the current domain.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
